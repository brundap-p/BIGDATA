from pyspark.sql import SparkSession

spark = SparkSession.builder.appName("TrendAnalysis").getOrCreate()
sc = spark.sparkContext

# Load CSV file
rdd = sc.textFile("/content/NASA Dataset for LSTM.csv")

# Remove header
header = rdd.first()
data = rdd.filter(lambda x: x!= header)

# Extract request count column
counts = data.map(lambda x: int(x.split(",")[1]))

# MapReduce: Calculate total requests
total_requests = counts.map(lambda x: ("Total Requests", x)) \
.reduceByKey(lambda a,b:a+b)

print("Web Traffic Summary")
for row in total_requests.collect():
    print(row)

spark.stop()
