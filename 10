from pyspark.sql import SparkSession

spark = SparkSession.builder.appName("ServiceRatingPrediction").
getOrCreate()
sc = spark.sparkContext

# Load CSV
rdd = sc.textFile("/content/googleplaystore.csv")

# Remove header
header = rdd.first()
data = rdd.filter(lambda x: x!= header)

# Extract Category and Rating
ratings = data.map(lambda x: x.split(","))

# Keep valid ratings
valid = ratings.filter(
    lambda x: len(x) > 2 and x[2].replace(".", "", 1).isdigit()
)

# MapReduce for average rating
mapped = valid.map(
    lambda x: (x[1], (float(x[2]), 1))
)

result = mapped.reduceByKey(
    lambda a, b: (a[0] + b[0], a[1] + b[1])
)

avg_rating = result.mapValues(
    lambda x: round(x[0] / x[1], 2)
)

print("Average Rating by Category\n")
for row in avg_rating.take(10):
    print(row)

spark.stop()
